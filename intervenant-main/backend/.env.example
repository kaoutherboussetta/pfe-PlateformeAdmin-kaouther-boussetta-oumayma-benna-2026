# Copier vers .env — même style que flutter_backend (MONGO_URI en Atlas).
# Si erreur querySrv ENOTFOUND _mongodb._tcp.CLUSTER... : l’URI contient encore
# « CLUSTER » ou un hôte fictif — remplacez par l’hôte réel Atlas (Connect → Drivers).
# Optionnel : backend/.env.local surcharge .env (priorité au local).
# Débogage URI : lancer avec DEBUG_MONGO=1 (affiche l’URI complète dans le terminal).

# Atlas (recommandé, comme app_trig_essalama-main/flutter_backend) :
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/trig_essalama?retryWrites=true&w=majority

# MongoDB local :
# MONGO_URI=mongodb://127.0.0.1:27017/trig_essalama

# Alias accepté :
# MONGODB_URI=...

## PORT du backend (3000 partout : Flutter kBackendDefaultPort, ngrok `ngrok http 3000`)
PORT=3000
# Défaut server.js = 1 : le serveur n’essaie pas 3001 si 3000 est pris (évite de casser le tunnel ngrok).
# Augmentez seulement si vous n’utilisez pas ngrok : PORT_TRY_COUNT=15
PORT_TRY_COUNT=1
# Si « port déjà utilisé » : netstat -ano | findstr :3000 puis taskkill /PID <pid> /F

# Collection MongoDB des alertes (défaut : alerts). Si Atlas utilise le singulier :
# NOTIFICATIONS_ALERT_COLLECTION=alert

# Collection problèmes IA / voirie (détail mobile, GET /api/problemes-voirie)
# PROBLEMES_VOIRIE_COLLECTION=problemes_de_voirie
